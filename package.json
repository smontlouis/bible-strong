{
  "name": "bible-strong",
  "version": "25.1.1",
  "main": "expo-router/entry",
  "scripts": {
    "eas-build-pre-install": "corepack enable",
    "start": "expo start --dev-client",
    "update:staging": "npx eas update --channel staging",
    "update:production": "npx eas update --channel production",
    "build:android:dev": "rm -rf \"${TMPDIR}metro-cache\" && dotenv -c development -- eas build -p android --local --profile development --non-interactive",
    "build:android:staging": "rm -rf \"${TMPDIR}metro-cache\" && dotenv -c staging -- eas build -p android --local --profile staging --non-interactive",
    "build:android:prod": "rm -rf \"${TMPDIR}metro-cache\" && dotenv -c production -- eas build -p android --local --profile production --non-interactive",
    "build:android:prod:apk": "rm -rf \"${TMPDIR}metro-cache\" && dotenv -c production -- eas build -p android --local --profile production-apk --non-interactive",
    "build:ios:dev": "rm -rf \"${TMPDIR}metro-cache\" && dotenv -c development -- eas build -p ios --local --profile development --non-interactive",
    "build:ios:dev-sim": "rm -rf \"${TMPDIR}metro-cache\" && dotenv -c development -- eas build -p ios --local --profile development-simulator --non-interactive",
    "build:ios:staging": "rm -rf \"${TMPDIR}metro-cache\" && dotenv -c staging -- eas build -p ios --local --profile staging --non-interactive",
    "build:ios:prod": "rm -rf \"${TMPDIR}metro-cache\" && dotenv -c production -- eas build -p ios --local --profile production --non-interactive",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watchAll",
    "test": "node ./node_modules/jest/bin/jest.js",
    "clean": "rm -rf pnpm-lock.json && rm -rf node_modules && rm -rf $TMPDIR/metro-* && rm -rf $TMPDIR/haste-map-* && pnpm && say I love react native",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\" \"docs/assets/app-flows/**/*.{html,js,jsx,mjs,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\" \"docs/assets/app-flows/**/*.{html,js,jsx,mjs,css}\"",
    "typecheck": "tsc --noEmit",
    "i18n": "i18next 'src/**/*.{js,ts,tsx}' '!src/features/bible/bibleWebView/**' '!src/features/studies/studiesWebView/**'",
    "agents:start:logged": "node scripts/agents-start-logged.mjs",
    "agents:architecture": "node scripts/agents-architecture-lint.mjs",
    "agents:architecture:check": "node scripts/agents-architecture-lint.mjs --check",
    "agents:quality": "node scripts/agents-quality-report.mjs",
    "agents:quality:check": "node scripts/agents-quality-report.mjs --check",
    "agents:logs:clear": "node scripts/agents-log-session.mjs clear",
    "agents:logs:all": "node scripts/agents-log-session.mjs all",
    "agents:logs:errors": "node scripts/agents-log-session.mjs errors",
    "agents:logs:startup": "node scripts/agents-log-session.mjs startup",
    "agents:logs:navigation": "node scripts/agents-log-session.mjs navigation",
    "agents:issue:start": "node scripts/agents-issue-start.mjs",
    "agents:issue:pr": "node scripts/agents-issue-pr.mjs",
    "agents:issue:run": "node scripts/agents-issue-run.mjs",
    "docs:flows:data": "node docs/assets/app-flows/scripts/generate-app-flow-data.mjs",
    "docs:flows:build": "yarn docs:flows:data && vite build --config docs/assets/app-flows/viewer/vite.config.mjs",
    "docs:flows:dev": "yarn docs:flows:data && vite --config docs/assets/app-flows/viewer/vite.config.mjs",
    "bible:dbr:generate": "node scripts/generate-dbr-bible.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
