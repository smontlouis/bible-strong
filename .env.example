# App identity
APP_NAME="dev - Bible Strong"
BUNDLE_IDENTIFIER="com.smontlouis.biblestrong.dev"

# Firebase config files
IOS_GOOGLE_SERVICES_FILE="./firebase/dev/GoogleService-Info.plist"
ANDROID_GOOGLE_SERVICES_FILE="./firebase/dev/google-services.json"

# Public runtime config
EXPO_PUBLIC_SENTRY_DSN=""
EXPO_PUBLIC_DEEPL_AUTH_KEY=""
EXPO_NO_BUNDLE_SPLITTING=true

# EAS Updates channel. Leave blank for local development.
EAS_BUILD_CHANNEL=""

# Play Store review scripts
PACKAGE_NAME="com.smontlouis.biblestrong"
GOOGLE_SERVICE_ACCOUNT_PATH="./scripts/google-service-account.json"
